---
import '../styles/global.css';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import PainSection from '../components/PainSection.astro';
import EasierWay from '../components/EasierWay.astro';
import WhatYoullLearn from '../components/WhatYoullLearn.astro';
import IsThisCoachingForYou from '../components/IsThisCoachingForYou.astro';
import PricingBonuses from '../components/PricingBonuses.astro';
import PricingOffer from '../components/PricingOffer.astro';
import MoneyBackGuarantee from '../components/MoneyBackGuarantee.astro';
import SuccessStories from '../components/SuccessStories.astro';
import OldVsNew from '../components/OldVsNew.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Modules from '../components/Modules.astro';
import Testimonials from '../components/Testimonials.astro';
import IsThisForYou from '../components/IsThisForYou.astro';
import Community from '../components/Community.astro';
import Bonuses from '../components/Bonuses.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import StickyBottomCTA from '../components/StickyBottomCTA.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Pakistan's #1 AI Content Creation Mentorship. Learn AI product photography, videos, influencers, voice cloning & avatars. Replace costly shoots with AI." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>AI Guy — Pakistan's #1 AI Content Creation Mentorship</title>
    <!-- Netlify Identity (required for CMS login redirect) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <!-- 1. Sticky announcement ticker -->
    <AnnouncementBar />
    <!-- 2. Sticky navbar -->
    <Navbar />

    <main>
      <!-- 3. Hero (outside stack — anchors the page) -->
      <Hero />

      <IsThisForYou />
      <OldVsNew />
      <PainSection />
      <EasierWay />
      <WhatYoullLearn />
      <IsThisCoachingForYou />
      <PricingBonuses />
      <PricingOffer />
      <MoneyBackGuarantee />
      <SuccessStories />
      <FAQ />
    </main>

    <!-- 17. Footer -->
    <Footer />
    <!-- 18. Sticky Bottom CTA -->
    <StickyBottomCTA />

    <!-- Netlify Identity redirect handler -->
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user: unknown) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>

  </body>
</html>
