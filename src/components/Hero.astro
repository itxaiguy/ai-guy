---
import data from '../content/hero.json';
import videos from '../content/videos.json';
---

<section class="relative overflow-hidden bg-[#110008] pb-12" style="padding-top:0;">

  <!-- ── Navbar (inside hero so bg matches) ── -->
  <div class="hero-nav" style="margin-top:36px;">
    <div style="width:44px;"></div>
    <a href="#" class="hero-nav-logo">
      <img src="/logo.png" alt="AI Guy" style="height:52px;width:auto;object-fit:contain;" />
    </a>
    <button class="hero-nav-burger" id="nav-toggle" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Right-side drawer -->
  <div class="nav-drawer" id="nav-drawer">
    <div class="nav-drawer-header">
      <button class="nav-drawer-close" id="nav-close" aria-label="Close menu">✕</button>
    </div>
    <nav class="nav-drawer-links">
      <a href="#how-it-works"  class="nav-drawer-link">How It Works</a>
      <a href="#modules"       class="nav-drawer-link">Modules</a>
      <a href="#community"     class="nav-drawer-link">Community</a>
      <a href="#testimonials"  class="nav-drawer-link">Testimonials</a>
      <a href="#faq"           class="nav-drawer-link">FAQ</a>
    </nav>
  </div>
  <div class="nav-backdrop" id="nav-backdrop"></div>

  <script>
    const toggle   = document.getElementById('nav-toggle');
    const drawer   = document.getElementById('nav-drawer');
    const backdrop = document.getElementById('nav-backdrop');
    const closeBtn = document.getElementById('nav-close');

    function openNav()  { drawer?.classList.add('open'); backdrop?.classList.add('open'); toggle?.classList.add('open'); }
    function closeNav() { drawer?.classList.remove('open'); backdrop?.classList.remove('open'); toggle?.classList.remove('open'); }

    toggle?.addEventListener('click', openNav);
    closeBtn?.addEventListener('click', closeNav);
    backdrop?.addEventListener('click', closeNav);
    document.querySelectorAll('.nav-drawer-link').forEach(l => l.addEventListener('click', closeNav));
  </script>

  <!-- Background radial glow -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[500px] rounded-full"
      style="background: radial-gradient(ellipse at center, rgba(160,0,40,0.45) 0%, rgba(80,0,20,0.2) 50%, transparent 75%);"></div>
  </div>

  <div class="relative z-10 max-w-lg lg:max-w-5xl mx-auto px-4 lg:px-8">
    <div class="text-center">

    <!-- Shiny animated border pill -->
    <div class="flex justify-center mb-6">
      <div class="shiny-pill-wrapper">
        <div class="shiny-pill-rotator"></div>
        <div class="shiny-pill-inner flex items-center gap-2.5 px-4 py-2">
          <div class="flex -space-x-2 shrink-0">
            {data.avatar1
              ? <img src={data.avatar1} alt="Student" class="w-7 h-7 rounded-full border border-[#FF2C57] object-cover" />
              : <div class="w-7 h-7 rounded-full border border-[#FF2C57] bg-gradient-to-br from-orange-400 to-red-600"></div>}
            {data.avatar2
              ? <img src={data.avatar2} alt="Student" class="w-7 h-7 rounded-full border border-[#FF2C57] object-cover" />
              : <div class="w-7 h-7 rounded-full border border-[#FF2C57] bg-gradient-to-br from-blue-400 to-purple-600"></div>}
            {data.avatar3
              ? <img src={data.avatar3} alt="Student" class="w-7 h-7 rounded-full border border-[#FF2C57] object-cover" />
              : <div class="w-7 h-7 rounded-full border border-[#FF2C57] bg-gradient-to-br from-green-400 to-teal-600"></div>}
          </div>
          <span class="text-white text-[13px] font-medium whitespace-nowrap">{data.tag}</span>
          <span class="text-[#FF2C57] font-bold text-[11px] leading-none shrink-0">→</span>
        </div>
      </div>
    </div>

    <!-- Hero Headline -->
    <h1 class="font-['FuturaPTCond'] font-bold uppercase text-white mb-6 leading-[1.05] px-2" style="font-size: clamp(2.4rem, 7vw, 5rem);">
      {data.headline1}<br/>
      <span class="text-[#FF2C57]">{data.headline_accent}</span> {data.headline2}
    </h1>

    <!-- Video Card — full width on desktop -->
    <div class="relative mx-auto mb-6 w-full lg:max-w-4xl">
      <!-- Outer glow layers -->
      <div class="absolute -inset-3 rounded-3xl video-glow-outer"
        style="background: radial-gradient(ellipse at center, rgba(255,44,87,0.55) 0%, rgba(180,0,40,0.3) 50%, transparent 75%); filter: blur(18px);"></div>
      <div class="absolute -inset-1 rounded-3xl video-glow-inner"
        style="background: linear-gradient(135deg, #FF2C57 0%, #ff6b35 50%, #FF2C57 100%); filter: blur(8px);"></div>

      <!-- Video container -->
      <div class="relative rounded-3xl overflow-hidden border border-[#FF2C57]/60 bg-[#1a0010]"
        style="aspect-ratio: 16/9;">

        {videos.hero_video ? (
          <iframe
            src={videos.hero_video}
            class="w-full h-full"
            frameborder="0"
            allow="autoplay; fullscreen"
            allowfullscreen
          />
        ) : data.hero_image ? (
          <img
            src={data.hero_image}
            alt="AI Content"
            class="w-full h-full object-cover"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-[#2a0015] to-[#1a0008]">
            <!-- Play button -->
            <div class="w-16 h-16 rounded-full bg-[#FF2C57] flex items-center justify-center shadow-[0_0_30px_rgba(255,44,87,0.7)] cursor-pointer">
              <svg class="w-7 h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>
        )}

      </div>
    </div>

    <!-- CTA Button -->
    <div class="flex justify-center mb-4">
      <a href="#pricing" class="hero-cta-btn font-['FuturaPTCond'] font-bold uppercase tracking-wide text-white text-xl lg:text-2xl py-4 px-16">
        {data.cta_text}
      </a>
    </div>

    <!-- Social proof row -->
    <div class="flex items-center justify-center gap-3 mb-8">
      <div class="flex -space-x-2 shrink-0">
        {data.avatar1
          ? <img src={data.avatar1} alt="Student" class="w-8 h-8 rounded-full border-2 border-[#FF2C57] object-cover" />
          : <div class="w-8 h-8 rounded-full border-2 border-[#FF2C57] bg-gradient-to-br from-orange-400 to-red-500"></div>}
        {data.avatar2
          ? <img src={data.avatar2} alt="Student" class="w-8 h-8 rounded-full border-2 border-[#FF2C57] object-cover" />
          : <div class="w-8 h-8 rounded-full border-2 border-[#FF2C57] bg-gradient-to-br from-blue-400 to-purple-600"></div>}
        {data.avatar3
          ? <img src={data.avatar3} alt="Student" class="w-8 h-8 rounded-full border-2 border-[#FF2C57] object-cover" />
          : <div class="w-8 h-8 rounded-full border-2 border-[#FF2C57] bg-gradient-to-br from-green-400 to-teal-500"></div>}
      </div>
      <div class="text-left">
        <div class="text-[#f59e0b] text-sm tracking-tight">★★★★★</div>
        <p class="text-gray-400 text-xs">Join {data.student_count} business owners</p>
      </div>
    </div>

    </div><!-- end text-center -->
  </div>

  <!-- Proof bar: static items, animated lines centered with edge fade -->
  <div class="proof-bar">
    <div class="proof-inner">
      <!-- Top line: moves right -->
      <div class="proof-line-wrap">
        <div class="proof-line proof-line--right"></div>
      </div>

      <!-- Static items -->
      <div class="proof-items-row">
        {data.proof_items.map((item) => (
          <div class="proof-item">
            <img src="/checkmark.png" class="proof-check" alt="✓" />
            <span class="proof-text">{item}</span>
          </div>
        ))}
      </div>

      <!-- Bottom line: moves left -->
      <div class="proof-line-wrap">
        <div class="proof-line proof-line--left"></div>
      </div>
    </div>
  </div>

  <!-- Bottom fade — blends hero into next section -->
  <div class="hero-bottom-fade" aria-hidden="true"></div>

</section>

<style>
  /* ── Navbar ── */
  .hero-nav {
    position: relative;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 72px;
    margin-bottom: 24px;
  }
  .hero-nav-logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .hero-nav-burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 10px;
    cursor: pointer;
    padding: 10px;
    transition: background 0.2s;
  }
  .hero-nav-burger:hover { background: rgba(255,255,255,0.14); }
  .hero-nav-burger span {
    display: block;
    width: 100%;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.2s ease;
    transform-origin: center;
  }
  .hero-nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hero-nav-burger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hero-nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Right-side drawer ── */
  .nav-drawer {
    position: fixed;
    top: 36px; right: 0;
    width: 260px;
    height: auto;
    z-index: 70;
    background: #0f0a10;
    border-left: 1px solid rgba(255,44,87,0.2);
    border-bottom: 1px solid rgba(255,44,87,0.2);
    border-bottom-left-radius: 16px;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }
  .nav-drawer.open { transform: translateX(0); }

  .nav-drawer-header {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 20px 20px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-drawer-close {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: #fff;
    font-size: 1rem;
    width: 36px;
    height: 36px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .nav-drawer-close:hover { background: rgba(255,44,87,0.2); }

  .nav-drawer-links {
    display: flex;
    flex-direction: column;
    padding: 16px 0;
    flex: 1;
  }
  .nav-drawer-link {
    font-family: 'FuturaPTCond', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #ccc;
    text-decoration: none;
    padding: 16px 28px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: color 0.15s, background 0.15s, padding-left 0.2s;
  }
  .nav-drawer-link:last-child { border-bottom: none; }
  .nav-drawer-link:hover { color: #FF2C57; background: rgba(255,44,87,0.05); padding-left: 36px; }

  /* ── Backdrop ── */
  .nav-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 69;
    background: transparent;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .nav-backdrop.open { display: block; opacity: 1; }

  @font-face {
    font-family: 'Gilmer';
    src: url('/fonts/gilmer-medium.ttf') format('truetype');
    font-weight: 500;
    font-display: swap;
  }

  /* Shiny rotating border pill */
  .shiny-pill-wrapper {
    position: relative;
    display: inline-block;
    padding: 1.5px;
    border-radius: 9999px;
    overflow: hidden;
  }

  .shiny-pill-rotator {
    position: absolute;
    inset: -200%;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 55deg,
      #FF2C57 85deg,
      #ff8c5a 105deg,
      #ffffff 125deg,
      #ff8c5a 145deg,
      #FF2C57 165deg,
      transparent 195deg,
      transparent 360deg
    );
    animation: shiny-spin 3s linear infinite;
  }

  .shiny-pill-inner {
    position: relative;
    z-index: 1;
    background: rgba(30, 0, 15, 0.85);
    border-radius: 9999px;
    backdrop-filter: blur(4px);
  }

  @keyframes shiny-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* CTA Button */
  .hero-cta-btn {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    background: linear-gradient(135deg, #FF2C57 0%, #ff4d6d 100%);
    box-shadow: 0 0 40px rgba(255, 44, 87, 0.6), 0 4px 20px rgba(255, 44, 87, 0.4);
    transition: box-shadow 0.2s;
    text-align: center;
    display: inline-block;
  }
  .hero-cta-btn:hover {
    box-shadow: 0 0 55px rgba(255, 44, 87, 0.75), 0 4px 24px rgba(255, 44, 87, 0.5);
  }

  /* Shimmer sweep right-to-left */
  .hero-cta-btn::after {
    content: '';
    position: absolute;
    top: 0;
    right: -80%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      rgba(255, 255, 255, 0.18) 40%,
      rgba(255, 255, 255, 0.38) 50%,
      rgba(255, 255, 255, 0.18) 60%,
      transparent 80%
    );
    transform: skewX(-15deg);
    animation: btn-shimmer 2.4s ease-in-out infinite;
  }

  @keyframes btn-shimmer {
    0%   { right: -80%; }
    100% { right: 120%; }
  }

  /* ── Proof bar ── */
  .proof-bar {
    width: 100%;
    margin-top: 32px;
    margin-bottom: 0;
    background: transparent;
  }

  /* Centered container — lines and items live here */
  .proof-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  /* Line wrapper: applies edge-fade mask */
  .proof-line-wrap {
    width: 100%;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 18%, black 82%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 18%, black 82%, transparent 100%);
  }

  /* The animated glowing line */
  .proof-line {
    width: 100%;
    height: 2px;
    background-size: 200% 100%;
    background-image: linear-gradient(
      90deg,
      #3a0010 0%,
      #FF2C57 25%,
      #ff8c6a 50%,
      #FF2C57 75%,
      #3a0010 100%
    );
    box-shadow: 0 0 6px 1px rgba(255, 44, 87, 0.7), 0 0 14px 2px rgba(255, 44, 87, 0.3);
  }

  .proof-line--right {
    animation: line-right 3s linear infinite;
  }
  .proof-line--left {
    animation: line-left 3s linear infinite;
  }

  /* Static items row */
  .proof-items-row {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 0;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 18%, black 82%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 18%, black 82%, transparent 100%);
  }

  .proof-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 32px;
    border-right: 1px solid rgba(255, 44, 87, 0.25);
  }
  .proof-item:last-child {
    border-right: none;
  }

  .proof-check {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    filter: brightness(0) saturate(100%) invert(22%) sepia(96%) saturate(4000%) hue-rotate(333deg) brightness(105%);
  }

  .proof-text {
    font-family: 'Gilmer', sans-serif;
    font-weight: 500;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #ffffff;
    line-height: 1.3;
    text-align: left;
    white-space: nowrap;
  }

  /* Line shimmer moves right */
  @keyframes line-right {
    0%   { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }
  /* Line shimmer moves left */
  @keyframes line-left {
    0%   { background-position: 200% 0%; }
    100% { background-position: 0% 0%; }
  }

  /* Bottom section fade */
  .hero-bottom-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent 0%, #0a0a0a 100%);
    pointer-events: none;
    z-index: 20;
  }

  /* Video glow pulse */
  .video-glow-outer {
    animation: video-pulse 2.8s ease-in-out infinite;
  }
  .video-glow-inner {
    animation: video-pulse 2.8s ease-in-out infinite 0.4s;
  }
  @keyframes video-pulse {
    0%, 100% { opacity: 0.15; }
    50%       { opacity: 1; }
  }
</style>
