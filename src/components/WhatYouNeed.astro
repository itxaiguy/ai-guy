---
const requirements = [
  { icon: "📱", text: "A smartphone (any Android or iPhone)" },
  { icon: "🌐", text: "Basic internet connection" },
  { icon: "⏰", text: "30–60 minutes per day" },
  { icon: "🇵🇰", text: "Pakistani SIM or ID" },
  { icon: "💡", text: "Zero prior experience needed" },
];
---
<section class="py-12 bg-[#0d0d0d]">
  <div class="max-w-lg mx-auto px-4">
    <div class="text-center mb-8">
      <div class="section-tag">Requirements</div>
      <h2 class="font-['Oswald'] text-3xl font-bold uppercase text-white">
        FOR CASH IN TIKTOK CRP<br/>
        <span class="text-[#00d4b4]">YOU ONLY NEED:</span>
      </h2>
    </div>

    <!-- Phone mockup + list -->
    <div class="flex flex-col items-center gap-6">
      <!-- Phone placeholder -->
      <div class="w-36 h-64 bg-[#111] border-2 border-[#1e1e1e] rounded-3xl flex items-center justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-[#cc1a1a]/10 to-[#ff1f5e]/10"></div>
        <div class="text-center z-10">
          <svg class="w-12 h-12 mx-auto mb-2 text-gray-600 opacity-60" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.27 8.27 0 004.84 1.55V6.86a4.85 4.85 0 01-1.07-.17z"/>
          </svg>
          <span class="text-gray-500 text-xs">TikTok App</span>
        </div>
      </div>

      <!-- Requirements list -->
      <ul class="w-full space-y-3">
        {requirements.map(r => (
          <li class="card-dark flex items-center gap-4">
            <span class="text-2xl">{r.icon}</span>
            <span class="text-white font-medium text-sm">{r.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
