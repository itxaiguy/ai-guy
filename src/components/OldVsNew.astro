---
const oldWay = [
  "Pay Rs. 30,000–150,000 per product shoot",
  "Book studios, photographers & models weeks in advance",
  "Wait days/weeks for edited content",
  "Pay influencers Rs. 20,000–500,000 per post",
  "Limited content variations per shoot",
  "Re-shoot every time products or seasons change",
  "Overpay for video production agencies",
];

const newWay = [
  "Create unlimited product photos for free, after learning",
  "No studio, no bookings — create from your laptop",
  "Content ready in hours, not weeks",
  "AI influencers that work for you 24/7 at zero per-post cost",
  "Infinite variations, angles, backgrounds & styles",
  "Update content anytime — instantly",
  "Produce professional brand videos yourself",
];
---
<section class="py-14 bg-[#0a0a0a]">
  <div class="max-w-lg mx-auto px-4">
    <div class="text-center mb-10">
      <div class="section-tag">💡 The Shift</div>
      <h2 class="font-['Oswald'] text-3xl font-bold uppercase text-white mt-2">
        THE OLD WAY IS<br/>
        <span class="text-[#ff1f5e]">COSTING YOU TOO MUCH</span>
      </h2>
      <p class="text-gray-400 text-sm mt-3">
        AI is changing content creation. Here's what smart brands are switching to.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <!-- Old Way -->
      <div class="rounded-2xl border border-[#cc1a1a]/30 bg-[#110808] p-4">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 rounded-full bg-[#cc1a1a]/20 flex items-center justify-center text-sm">❌</div>
          <p class="font-['Oswald'] font-bold text-[#cc1a1a] text-sm uppercase tracking-wide">Old Way</p>
        </div>
        <ul class="space-y-3">
          {oldWay.map(item => (
            <li class="flex items-start gap-2 text-xs text-gray-400 leading-snug">
              <span class="text-[#cc1a1a] shrink-0 mt-0.5">✗</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- New Way -->
      <div class="rounded-2xl border border-[#00d4b4]/30 bg-[#08110f] p-4 relative overflow-hidden">
        <div class="absolute inset-0 bg-[#00d4b4]/5 pointer-events-none rounded-2xl"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-7 h-7 rounded-full bg-[#00d4b4]/20 flex items-center justify-center text-sm">✅</div>
            <p class="font-['Oswald'] font-bold text-[#00d4b4] text-sm uppercase tracking-wide">AI Guy Way</p>
          </div>
          <ul class="space-y-3">
            {newWay.map(item => (
              <li class="flex items-start gap-2 text-xs text-gray-200 leading-snug">
                <span class="text-[#00d4b4] shrink-0 mt-0.5">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-8 text-center">
      <a href="#pricing" class="btn-primary w-full block text-lg py-4">
        I WANT THE SMARTER WAY →
      </a>
      <p class="text-gray-500 text-xs mt-3">Join [X]+ brands & marketers already using AI content</p>
    </div>
  </div>
</section>
