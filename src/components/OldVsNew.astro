---
import data from '../content/oldvsnew.json';
const { heading, heading_accent, old_way, new_way } = data;
---

<section class="bg-[#0a0a0a] py-14">
  <div class="max-w-lg lg:max-w-7xl mx-auto px-4 lg:px-8">

    <!-- Heading: FuturaPTCond -->
    <h2 class="font-['FuturaPTCond'] font-bold uppercase text-center text-white leading-tight mb-8"
        style="font-size: clamp(2rem, 6vw, 4rem);">
      {heading} <span class="text-[#FF2C57]">{heading_accent}</span>
    </h2>

    <!-- Cards: stacked on mobile, 3-col on desktop (card | VS | card) -->
    <div class="flex flex-col lg:grid lg:items-stretch" style="grid-template-columns: 1fr 80px 1fr; gap: 0 16px;">

    <!-- OLD WAY card -->
    <div class="oldway-card rounded-2xl p-6 lg:p-10 mb-4 lg:mb-0">
      <ul class="space-y-5 lg:space-y-7">
        {old_way.map(item => (
          <li class="flex items-center gap-4">
            <span class="shrink-0">
              <svg width="28" height="28" viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="10" r="9" stroke="#FF2C57" stroke-width="1.5"/>
                <path d="M7 7L13 13M13 7L7 13" stroke="#FF2C57" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="font-['FuturaPTCond'] text-white text-base lg:text-xl leading-snug tracking-wide">{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- VS badge — own column on desktop, divider on mobile -->
    <div class="flex items-center justify-center my-2 lg:my-0">
      <span class="font-['FuturaPTCond'] font-bold text-[#FF2C57] leading-none" style="font-size: clamp(2.5rem, 4vw, 4rem);">VS</span>
    </div>

    <!-- NEW WAY card -->
    <div class="newway-card rounded-2xl p-6 lg:p-10 mt-2 lg:mt-0">
      <ul class="space-y-5 lg:space-y-7">
        {new_way.map(item => (
          <li class="flex items-center gap-4">
            <span class="shrink-0">
              <svg width="28" height="28" viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="10" r="9" stroke="#22c55e" stroke-width="1.5"/>
                <path d="M6 10.5L8.5 13L14 7.5" stroke="#22c55e" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="font-['FuturaPTCond'] text-white text-base lg:text-xl leading-snug tracking-wide">{item}</span>
          </li>
        ))}
      </ul>
    </div>

    </div><!-- end grid -->

  </div>
</section>

<style>
  .oldway-card {
    background: linear-gradient(160deg, #3a0a10 0%, #2a0609 60%, #1a0406 100%);
    border: 1.5px solid rgba(255, 44, 87, 0.55);
    box-shadow: 0 0 30px rgba(255, 44, 87, 0.15), inset 0 0 40px rgba(180, 0, 30, 0.12);
    animation: pulse-red 3s ease-in-out infinite;
  }

  .newway-card {
    background: linear-gradient(160deg, #0a3a16 0%, #072a10 60%, #041a09 100%);
    border: 1.5px solid rgba(34, 197, 94, 0.55);
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.15), inset 0 0 40px rgba(0, 140, 50, 0.12);
    animation: pulse-green 3s ease-in-out infinite;
  }

  @keyframes pulse-red {
    0%, 100% {
      box-shadow: 0 0 20px rgba(255, 44, 87, 0.1), inset 0 0 30px rgba(180, 0, 30, 0.08);
      border-color: rgba(255, 44, 87, 0.4);
    }
    50% {
      box-shadow: 0 0 45px rgba(255, 44, 87, 0.45), inset 0 0 50px rgba(200, 0, 40, 0.2);
      border-color: rgba(255, 44, 87, 0.85);
    }
  }

  @keyframes pulse-green {
    0%, 100% {
      box-shadow: 0 0 20px rgba(34, 197, 94, 0.1), inset 0 0 30px rgba(0, 140, 50, 0.08);
      border-color: rgba(34, 197, 94, 0.4);
    }
    50% {
      box-shadow: 0 0 45px rgba(34, 197, 94, 0.45), inset 0 0 50px rgba(0, 160, 60, 0.2);
      border-color: rgba(34, 197, 94, 0.85);
    }
  }
</style>
