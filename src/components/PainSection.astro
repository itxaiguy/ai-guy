---
const costs = [
  { label: "Product Photography Shoot", traditional: "Rs. 30,000 – 150,000", icon: "📸" },
  { label: "Influencer Post (1 post)", traditional: "Rs. 20,000 – 500,000", icon: "👤" },
  { label: "Video Production (1 ad)", traditional: "Rs. 50,000 – 200,000", icon: "🎬" },
  { label: "Model Fees (per shoot)", traditional: "Rs. 15,000 – 80,000", icon: "💃" },
];
---
<section class="py-14 bg-[#0a0a0a]">
  <div class="max-w-lg mx-auto px-4">
    <div class="text-center mb-8">
      <div class="section-tag">💸 The Real Problem</div>
      <h2 class="font-['Oswald'] text-3xl font-bold uppercase text-white mt-2">
        TRADITIONAL CONTENT<br/>
        IS <span class="text-[#ff1f5e]">DRAINING YOUR BUDGET</span>
      </h2>
      <p class="text-gray-400 text-sm mt-3 leading-relaxed">
        Every time you need fresh content for your brand, you're burning money on shoots, models, and influencers.
      </p>
    </div>

    <!-- Cost breakdown -->
    <div class="space-y-3 mb-6">
      {costs.map(c => (
        <div class="card-dark flex items-center gap-4">
          <span class="text-2xl shrink-0">{c.icon}</span>
          <div class="flex-1 min-w-0">
            <p class="text-white text-sm font-medium truncate">{c.label}</p>
            <p class="text-[#ff1f5e] text-xs font-bold mt-0.5">{c.traditional}</p>
          </div>
          <div class="shrink-0 text-[#cc1a1a] text-lg font-bold">↑</div>
        </div>
      ))}
    </div>

    <!-- Total callout -->
    <div class="rounded-2xl bg-gradient-to-br from-[#1a0808] to-[#0a0a0a] border border-[#cc1a1a]/30 p-5 text-center mb-6">
      <p class="text-gray-400 text-sm mb-1">A single brand campaign can cost you</p>
      <p class="font-['Oswald'] text-4xl font-bold text-[#ff1f5e]">Rs. 100,000+</p>
      <p class="text-gray-500 text-sm mt-1">…and that's just for a few pieces of content</p>
    </div>

    <!-- VS divider -->
    <div class="flex items-center gap-4 mb-6">
      <div class="flex-1 h-px bg-[#1e1e1e]"></div>
      <span class="font-['Oswald'] text-xl font-bold text-gray-500">VS</span>
      <div class="flex-1 h-px bg-[#1e1e1e]"></div>
    </div>

    <!-- AI solution callout -->
    <div class="rounded-2xl bg-gradient-to-br from-[#081a10] to-[#0a0a0a] border border-[#00d4b4]/30 p-5 text-center">
      <p class="text-gray-400 text-sm mb-1">With AI Guy mentorship, you learn to do it all for</p>
      <p class="font-['Oswald'] text-4xl font-bold text-[#00d4b4]">4,999 PKR</p>
      <p class="text-[#00d4b4] text-sm font-bold mt-1">One-time · Unlimited content · Forever</p>
      <ul class="mt-4 space-y-2 text-left">
        {[
          "No studio. No photographer. No model.",
          "No influencer deals. No waiting. No overpaying.",
          "Create unlimited AI content for any product, anytime.",
        ].map(item => (
          <li class="flex items-start gap-2 text-sm text-gray-300">
            <span class="text-[#00d4b4] shrink-0">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-8 text-center">
      <a href="#pricing" class="btn-primary w-full block text-lg py-4">
        START CREATING AI CONTENT →
      </a>
    </div>
  </div>
</section>
