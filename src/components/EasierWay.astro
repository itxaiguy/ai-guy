---
import data from '../content/easierway.json';
const { heading, heading_accent, body_p1, body_p2, body_p3, cta_text, social_proof_count, social_proof_label, carousel_cards } = data;
---

<section class="easier-way-section py-14 px-4">
  <div class="max-w-lg lg:max-w-6xl mx-auto">

    <!-- Mobile: single column | Desktop: two columns -->
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">

      <!-- LEFT COL: Heading + Coverflow -->
      <div>
        <!-- Heading -->
        <h2 class="font-['FuturaPTCond'] font-bold uppercase text-center lg:text-left leading-tight mb-8"
            style="font-size: clamp(3rem, 7vw, 5.5rem);">
          <span class="text-white">{heading}<br/></span>
          <span class="text-[#FF2C57]">{heading_accent}</span>
        </h2>

        <!-- 3D Coverflow Carousel -->
        <div class="coverflow-wrap mb-8">
          <div class="coverflow" id="coverflow">
            {carousel_cards.map((card, i) => (
              <div class="cf-card" data-index={i}>
                <div class="cf-inner" style={`background: ${card.bg};`}>
                  <div class="cf-label" style={`color:${card.labelColor};`}>{card.label}</div>
                  <div class="cf-title">{card.title}</div>
                  <div class="cf-play"><svg fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
                </div>
              </div>
            ))}
          </div>

          <!-- Dots -->
          <div class="cf-dots" id="cfDots"></div>
        </div>
      </div>

      <!-- RIGHT COL: Body text + CTA + Social proof -->
      <div>
        <!-- Body text -->
        <div class="space-y-5 mb-10 text-center lg:text-left">
          <p class="font-['Gilmer'] text-gray-300 text-base lg:text-xl leading-relaxed">{body_p1}</p>
          <p class="font-['Gilmer'] text-gray-300 text-base lg:text-xl leading-relaxed">{body_p2}</p>
          <p class="font-['Gilmer'] text-gray-300 text-base lg:text-xl leading-relaxed">{body_p3}</p>
        </div>

        <!-- CTA Button -->
        <div class="mb-6">
          <a href="#pricing" class="easier-cta-btn block w-full font-['FuturaPTCond'] font-bold uppercase tracking-wide text-white text-2xl lg:text-3xl py-5 px-8 text-center">
            {cta_text}
          </a>
        </div>

        <!-- Social proof row -->
        <div class="flex items-center justify-center lg:justify-start gap-4">
          <div class="flex -space-x-3 shrink-0">
            <div class="w-11 h-11 rounded-full border-2 border-[#FF2C57] bg-gradient-to-br from-orange-400 to-red-500 flex items-center justify-center text-sm">😊</div>
            <div class="w-11 h-11 rounded-full border-2 border-[#FF2C57] bg-gradient-to-br from-blue-400 to-purple-600 flex items-center justify-center text-sm">😊</div>
            <div class="w-11 h-11 rounded-full border-2 border-[#FF2C57] bg-gradient-to-br from-green-400 to-teal-500 flex items-center justify-center text-sm">😊</div>
            <div class="w-11 h-11 rounded-full border-2 border-[#FF2C57] bg-[#FF2C57] flex items-center justify-center text-xs font-bold text-white">{social_proof_count}</div>
          </div>
          <div class="text-left">
            <div class="text-[#f59e0b] text-lg">★★★★★</div>
            <p class="text-gray-400 text-sm">{social_proof_label}</p>
          </div>
        </div>
      </div>

    </div><!-- end lg:grid -->
  </div>
</section>

<style>
  .easier-way-section {
    background: #0a0a0a;
  }

  /* ── Coverflow ── */
  .coverflow-wrap {
    width: 100%;
    /* clip only left/right, let top shadow breathe */
    overflow-x: clip;
    overflow-y: visible;
    padding-top: 20px;
  }

  .coverflow {
    position: relative;
    height: 180px;
    perspective: 900px;
    transform-style: preserve-3d;
  }

  .cf-card {
    position: absolute;
    top: 0;
    left: 50%;
    width: 150px;
    height: 168px;
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94),
                opacity  0.55s ease,
                box-shadow 0.55s ease;
    transform-style: preserve-3d;
    border: 1px solid rgba(255,255,255,0.08);
  }

  @media (min-width: 1024px) {
    .coverflow {
      height: 290px;
      perspective: 1200px;
    }
    .cf-card {
      width: 240px;
      height: 265px;
      border-radius: 18px;
    }
    .cf-inner {
      padding: 24px 22px;
    }
    .cf-label {
      font-size: 0.82rem;
    }
    .cf-title {
      font-size: 1.1rem;
    }
    .cf-play {
      width: 50px;
      height: 50px;
    }
    .cf-play svg {
      width: 20px;
      height: 20px;
    }
  }

  .cf-inner {
    width: 100%; height: 100%;
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cf-label {
    font-family: 'FuturaPTCond', sans-serif;
    font-weight: 700;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .cf-title {
    font-family: 'FuturaPTCond', sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    color: white;
    line-height: 1.2;
  }

  .cf-play {
    margin-top: auto;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
  }
  .cf-play svg { width: 14px; height: 14px; color: white; margin-left: 2px; }

  /* Dot indicators */
  .cf-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 14px;
  }
  .cf-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    transition: background 0.3s, transform 0.3s;
    cursor: pointer;
  }
  .cf-dot.active {
    background: #FF2C57;
    transform: scale(1.3);
  }

  /* CTA button */
  .easier-cta-btn {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    background: linear-gradient(135deg, #FF2C57 0%, #ff4d6d 100%);
    box-shadow: 0 0 40px rgba(255,44,87,0.5), 0 4px 20px rgba(255,44,87,0.3);
    transition: box-shadow 0.2s;
  }
  .easier-cta-btn:hover {
    box-shadow: 0 0 55px rgba(255,44,87,0.7), 0 4px 24px rgba(255,44,87,0.5);
  }
  .easier-cta-btn::after {
    content: '';
    position: absolute;
    top: 0; right: -80%;
    width: 60%; height: 100%;
    background: linear-gradient(105deg, transparent 20%, rgba(255,255,255,0.18) 40%, rgba(255,255,255,0.38) 50%, rgba(255,255,255,0.18) 60%, transparent 80%);
    transform: skewX(-15deg);
    animation: btn-shimmer 2.4s ease-in-out infinite;
  }
  @keyframes btn-shimmer {
    0%   { right: -80%; }
    100% { right: 120%; }
  }
</style>

<script>
(function () {
  const track   = document.getElementById('coverflow');
  const dotsEl  = document.getElementById('cfDots');
  if (!track) return;

  const cards   = Array.from(track.querySelectorAll('.cf-card'));
  const total   = cards.length;
  let current   = 0;
  let autoTimer: ReturnType<typeof setInterval>;

  /* Build dots */
  cards.forEach((_, i) => {
    const d = document.createElement('span');
    d.className = 'cf-dot' + (i === 0 ? ' active' : '');
    d.addEventListener('click', () => goTo(i));
    dotsEl!.appendChild(d);
  });

  function goTo(idx: number) {
    current = (idx + total) % total;
    render();
    resetAuto();
  }

  function render() {
    const dots = dotsEl!.querySelectorAll('.cf-dot');
    const isDesktop = window.innerWidth >= 1024;
    const sideOffset = isDesktop ? 190 : 115;
    const sideZ      = isDesktop ? -120 : -80;

    cards.forEach((card, i) => {
      const offset = i - current;
      // Wrap-around distance
      let d = offset;
      if (d >  total / 2) d -= total;
      if (d < -total / 2) d += total;

      if (d === 0) {
        /* Centre — large, face-on */
        card.style.transform      = `translateX(-50%) translateZ(0px) rotateY(0deg) scale(1)`;
        card.style.opacity        = '1';
        card.style.zIndex         = '10';
        card.style.boxShadow      = '0 0 40px rgba(255,44,87,0.35), 0 8px 32px rgba(0,0,0,0.7)';
      } else if (d === -1 || d === total - 1) {
        /* Left — tilted wall */
        card.style.transform      = `translateX(calc(-50% - ${sideOffset}px)) translateZ(${sideZ}px) rotateY(42deg) scale(0.78)`;
        card.style.opacity        = '0.65';
        card.style.zIndex         = '5';
        card.style.boxShadow      = 'none';
      } else if (d === 1 || d === -(total - 1)) {
        /* Right — tilted wall */
        card.style.transform      = `translateX(calc(-50% + ${sideOffset}px)) translateZ(${sideZ}px) rotateY(-42deg) scale(0.78)`;
        card.style.opacity        = '0.65';
        card.style.zIndex         = '5';
        card.style.boxShadow      = 'none';
      } else {
        /* Far — hidden */
        card.style.transform      = `translateX(-50%) translateZ(-200px) scale(0.4)`;
        card.style.opacity        = '0';
        card.style.zIndex         = '1';
        card.style.boxShadow      = 'none';
      }
    });

    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  function resetAuto() {
    clearInterval(autoTimer);
    autoTimer = setInterval(() => goTo(current + 1), 3000);
  }

  /* Click a side card to bring it to centre */
  cards.forEach((card, i) => {
    card.addEventListener('click', () => goTo(i));
  });

  /* Touch / drag */
  let startX = 0;
  track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend',   (e) => {
    const dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) > 40) goTo(current + (dx < 0 ? 1 : -1));
  });

  render();
  resetAuto();
})();
</script>
