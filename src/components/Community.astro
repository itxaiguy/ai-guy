---
import data from '../content/community.json';
---
<section id="community" class="py-14 bg-[#0a0a0a]">
  <div class="max-w-lg lg:max-w-5xl mx-auto px-4 lg:px-8">
    <div class="relative rounded-3xl overflow-hidden border border-[#00d4b4]/30 bg-[#0d1a17] p-6 text-center mb-6">
      <div class="absolute inset-0 bg-[#00d4b4]/5 pointer-events-none"></div>
      <div class="inline-flex items-center gap-2 bg-[#00d4b4]/10 border border-[#00d4b4]/30 text-[#00d4b4] text-xs font-bold px-4 py-1.5 rounded-full mb-4">
        PRIVATE DISCORD COMMUNITY →
      </div>
      <h2 class="font-['Oswald'] text-3xl font-bold uppercase text-white leading-tight mb-3">
        <span class="text-[#00d4b4]" set:html={data.headline.replace('—', '<br/>')} />
      </h2>
      <p class="text-gray-400 text-sm mb-6 leading-relaxed">{data.desc}</p>

      <div class="grid grid-cols-3 gap-3 mb-6">
        {data.stats.map(s => (
          <div class="bg-[#0a0a0a]/60 rounded-xl py-3 px-2 text-center">
            <div class="text-[#00d4b4] font-['Oswald'] text-xl font-bold">{s.value}</div>
            <div class="text-gray-500 text-xs mt-0.5">{s.label}</div>
          </div>
        ))}
      </div>

      <div class="text-left mb-6 space-y-2">
        {data.features.map(f => (
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <span class="text-[#00d4b4] shrink-0">✓</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <a href="#pricing" class="w-full flex items-center justify-center gap-2 bg-[#5865F2] hover:bg-[#4752c4] text-white font-bold py-4 px-6 rounded-full transition-colors text-base uppercase tracking-wide">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
        </svg>
        ENROLL TO JOIN THE COMMUNITY
      </a>
    </div>

    <div class="card-dark text-center">
      <p class="text-gray-500 text-xs uppercase tracking-widest mb-4">Community member AI content samples</p>
      <div class="grid grid-cols-3 gap-2">
        {data.samples.map((s, i) => (
          s.image ? (
            <div class="rounded-xl overflow-hidden aspect-square">
              <img src={s.image} alt={`Community sample ${i+1}`} class="w-full h-full object-cover" />
            </div>
          ) : (
            <div class="bg-[#0a0a0a] rounded-xl aspect-square flex flex-col items-center justify-center text-gray-600 border border-[#1e1e1e]">
              <span class="text-2xl opacity-40 mb-1">🖼️</span>
              <span class="text-xs">Sample {i+1}</span>
            </div>
          )
        ))}
      </div>
    </div>
  </div>
</section>
