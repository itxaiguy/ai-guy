---
import data from '../content/successstories.json';
const { heading, heading_accent, subtitle, col1, col2, col3, col4 } = data;
---

<section class="ss-section py-16 px-4">
  <div class="max-w-7xl mx-auto">

    <!-- Headline -->
    <div class="mb-12">
      <h2 class="ss-headline">
        {heading}<br/>
        <span style="color:#FF2C57;">{heading_accent}</span>
      </h2>
      <p class="ss-sub">{subtitle}</p>
    </div>

    <!-- Scrolling viewport -->
    <div class="ss-viewport">

      <!-- Fade top & bottom -->
      <div class="ss-fade ss-fade--top"></div>
      <div class="ss-fade ss-fade--bottom"></div>

      <!-- 4 columns -->
      <div class="grid grid-cols-4 gap-4 h-full">

        <!-- Col 1: scroll DOWN -->
        <div class="overflow-hidden h-full">
          <div class="ss-track ss-track--down">
            {[...col1, ...col1].map(t => (
              <div class="ss-card">
                <div class="ss-author">
                  <div class="ss-avatar" style={`background:${t.avatarBg};`}>{t.name.charAt(0)}</div>
                  <span class="ss-name">{t.name}</span>
                </div>
                <p class="ss-quote">"{t.quote}"</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Col 2: scroll UP -->
        <div class="overflow-hidden h-full">
          <div class="ss-track ss-track--up">
            {[...col2, ...col2].map(t => (
              <div class="ss-card">
                <div class="ss-author">
                  <div class="ss-avatar" style={`background:${t.avatarBg};`}>{t.name.charAt(0)}</div>
                  <span class="ss-name">{t.name}</span>
                </div>
                <p class="ss-quote">"{t.quote}"</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Col 3: scroll DOWN -->
        <div class="overflow-hidden h-full">
          <div class="ss-track ss-track--down" style="animation-duration:28s;">
            {[...col3, ...col3].map(t => (
              <div class="ss-card">
                <div class="ss-author">
                  <div class="ss-avatar" style={`background:${t.avatarBg};`}>{t.name.charAt(0)}</div>
                  <span class="ss-name">{t.name}</span>
                </div>
                <p class="ss-quote">"{t.quote}"</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Col 4: scroll UP -->
        <div class="overflow-hidden h-full">
          <div class="ss-track ss-track--up" style="animation-duration:32s;">
            {[...col4, ...col4].map(t => (
              <div class="ss-card">
                <div class="ss-author">
                  <div class="ss-avatar" style={`background:${t.avatarBg};`}>{t.name.charAt(0)}</div>
                  <span class="ss-name">{t.name}</span>
                </div>
                <p class="ss-quote">"{t.quote}"</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .ss-section {
    background: #0a0a0a;
  }

  .ss-headline {
    font-family: 'FuturaPTCond', sans-serif;
    font-weight: 700;
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    color: #ffffff;
    text-transform: uppercase;
    line-height: 1.05;
    margin-bottom: 14px;
  }

  .ss-sub {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #888;
    max-width: 440px;
    line-height: 1.6;
  }

  /* Scrolling area */
  .ss-viewport {
    position: relative;
    height: 680px;
    overflow: hidden;
  }

  /* Fade gradients top & bottom */
  .ss-fade {
    position: absolute;
    left: 0; right: 0;
    height: 140px;
    z-index: 10;
    pointer-events: none;
  }
  .ss-fade--top {
    top: 0;
    background: linear-gradient(to bottom, #0a0a0a 0%, transparent 100%);
  }
  .ss-fade--bottom {
    bottom: 0;
    background: linear-gradient(to top, #0a0a0a 0%, transparent 100%);
  }

  /* Scrolling track */
  .ss-track {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Scroll DOWN: starts at -50%, moves to 0 */
  .ss-track--down {
    animation: scrollDown 24s linear infinite;
  }

  /* Scroll UP: starts at 0, moves to -50% */
  .ss-track--up {
    animation: scrollUp 24s linear infinite;
  }

  @keyframes scrollDown {
    from { transform: translateY(-50%); }
    to   { transform: translateY(0%); }
  }

  @keyframes scrollUp {
    from { transform: translateY(0%); }
    to   { transform: translateY(-50%); }
  }

  /* Card */
  .ss-card {
    background: #141414;
    border: 1px solid #222;
    border-radius: 14px;
    padding: 18px 18px 20px;
    flex-shrink: 0;
  }

  .ss-author {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .ss-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .ss-name {
    font-family: 'FuturaPTCond', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #FF2C57;
    line-height: 1;
  }

  .ss-quote {
    font-family: 'Inter', sans-serif;
    font-size: 0.83rem;
    color: #cccccc;
    line-height: 1.6;
  }
</style>
