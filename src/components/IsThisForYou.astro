---
const audiences = [
  {
    title: "Housewives",
    desc: "You want to earn from home without heavy investment, using only your phone and internet.",
  },
  {
    title: "Students",
    desc: "Turn your free time into extra monthly income by posting simple AI TikTok videos without ads, products, or clients.",
  },
  {
    title: "Freelancers",
    desc: "Stop depending on clients and deadlines. TikTok CRP gives you direct earnings with less stress and more consistency.",
  },
];
---

<section class="bg-[#0a0a0a] pt-16 pb-20">
  <div class="max-w-lg lg:max-w-6xl mx-auto px-4 lg:px-8">

    <!-- Tag -->
    <div class="flex justify-center mb-5">
      <span class="is-this-you-tag">IS THIS YOU?</span>
    </div>

    <!-- Heading -->
    <h2 class="font-['Oswald'] font-bold uppercase text-white text-center mb-4 leading-tight"
        style="font-size: clamp(2.8rem, 8vw, 4.5rem);">
      WHO IS THIS FOR?
    </h2>

    <!-- Subtitle -->
    <p class="text-center text-gray-400 italic text-base mb-12">See if you can relate.</p>

    <!-- Cards -->
    <div class="flex flex-col lg:grid lg:grid-cols-3 gap-6">
      {audiences.map(a => (
        <div class="audience-card">
          <h3 class="font-['Oswald'] font-bold text-white uppercase mb-4" style="font-size:clamp(1.6rem,3vw,2rem);">{a.title}</h3>
          <p class="text-gray-400 text-base lg:text-lg leading-relaxed">{a.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .is-this-you-tag {
    display: inline-block;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    border-radius: 9999px;
    padding: 6px 22px;
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
  }

  .audience-card {
    background: #141414;
    border: 1px solid #222222;
    border-radius: 20px;
    padding: 40px 36px;
  }
</style>
