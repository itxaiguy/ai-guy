---
const links = ["How It Works", "Modules", "Community", "Testimonials", "FAQ", "Enroll Now"];
---

<footer class="footer">
  <div class="footer-inner">

    <!-- Logo -->
    <a href="#" class="footer-logo">
      <span style="color:#FF2C57;">AI</span> GUY
    </a>

    <!-- Tagline -->
    <p class="footer-tagline">Pakistan's #1 AI Content Creation Mentorship</p>
    <p class="footer-services">AI Product Photography · AI Videos · AI Influencers · AI Voice · AI Avatars</p>

    <!-- Social icons -->
    <div class="footer-socials">
      <!-- Facebook -->
      <a href="#" class="footer-social-btn" style="background:#1877F2;" aria-label="Facebook">
        <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
      <!-- YouTube -->
      <a href="#" class="footer-social-btn" style="background:#FF0000;" aria-label="YouTube">
        <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
        </svg>
      </a>
      <!-- Instagram -->
      <a href="#" class="footer-social-btn" style="background:radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%);" aria-label="Instagram">
        <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
      <!-- TikTok -->
      <a href="#" class="footer-social-btn" style="background:#111; border:1.5px solid #333;" aria-label="TikTok">
        <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.27 8.27 0 004.84 1.55V6.86a4.85 4.85 0 01-1.07-.17z"/>
        </svg>
      </a>
    </div>

    <!-- Nav links -->
    <nav class="footer-nav">
      {links.map(link => (
        <a href={`#${link.toLowerCase().replace(/\s/g, '-')}`} class="footer-link">{link}</a>
      ))}
    </nav>

    <!-- Divider + copyright -->
    <div class="footer-bottom">
      <p class="footer-copy">© AI Guy 2025. All Rights Reserved.</p>
      <p class="footer-disclaimer">Results may vary. Individual success depends on effort, consistency, and application of the mentorship material.</p>
    </div>

  </div>
</footer>

<style>
  .footer {
    background: #0a0a0a;
    border-top: 1px solid #1e1e1e;
    padding: 80px 24px 60px;
  }

  .footer-inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* Logo */
  .footer-logo {
    font-family: 'FuturaPTCond', sans-serif;
    font-weight: 700;
    font-size: 2.8rem;
    letter-spacing: 0.12em;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 20px;
  }

  /* Tagline */
  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #888;
    margin-bottom: 10px;
  }

  .footer-services {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #555;
    margin-bottom: 36px;
    letter-spacing: 0.02em;
  }

  /* Social icons */
  .footer-socials {
    display: flex;
    justify-content: center;
    gap: 14px;
    margin-bottom: 40px;
  }

  .footer-social-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .footer-social-btn:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  /* Nav */
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px 28px;
    margin-bottom: 48px;
  }

  .footer-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: #666;
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: #ffffff; }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid #1e1e1e;
    padding-top: 28px;
    width: 100%;
  }

  .footer-copy {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #555;
    margin-bottom: 8px;
  }

  .footer-disclaimer {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: #3a3a3a;
    line-height: 1.5;
    max-width: 520px;
    margin: 0 auto;
  }
</style>
