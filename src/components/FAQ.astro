---
import data from '../content/faq.json';
const { faqs } = data;
---

<section id="faq" class="faq-section py-16 px-4">
  <div class="max-w-lg lg:max-w-3xl mx-auto">

    <!-- Outer card -->
    <div class="faq-card">

      <!-- Red pulsing glow in center -->
      <div class="faq-glow" aria-hidden="true"></div>

      <!-- Heading -->
      <div class="text-center mb-10 relative z-10">
        <h2 class="faq-headline">
          FREQUENTLY ASKED<br/>
          <span style="color:#FF2C57;">QUESTIONS</span>
        </h2>
      </div>

      <!-- FAQ items -->
      <div class="faq-list relative z-10">
        {faqs.map((faq, i) => (
          <details class="faq-item group">
            <summary class="faq-summary">
              <span class="faq-q">{i + 1}. {faq.q}</span>
              <span class="faq-icon">+</span>
            </summary>
            <p class="faq-answer">{faq.a}</p>
          </details>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .faq-section {
    background: #0a0a0a;
  }

  /* Outer dark card with rounded corners */
  .faq-card {
    background: #111111;
    border: 1px solid #1e1e1e;
    border-radius: 24px;
    padding: 52px 48px 48px;
    position: relative;
    overflow: hidden;
  }

  /* Red radial glow — pulses in center */
  .faq-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 44, 87, 0.45) 0%,
      rgba(255, 44, 87, 0.2)  35%,
      rgba(255, 44, 87, 0.06) 65%,
      transparent 100%
    );
    filter: blur(30px);
    pointer-events: none;
    animation: faq-glow-pulse 3s ease-in-out infinite;
    z-index: 0;
  }

  @keyframes faq-glow-pulse {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    50%       { opacity: 1;   transform: translate(-50%, -50%) scale(1.12); }
  }

  /* Heading */
  .faq-headline {
    font-family: 'FuturaPTCond', sans-serif;
    font-weight: 700;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    color: #ffffff;
    text-transform: uppercase;
    line-height: 1.05;
  }

  /* FAQ list */
  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .faq-item:last-child {
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 4px;
    cursor: pointer;
    list-style: none;
    gap: 16px;
  }
  .faq-summary::-webkit-details-marker { display: none; }

  .faq-q {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: #ffffff;
    line-height: 1.4;
  }

  .faq-icon {
    font-family: 'Inter', sans-serif;
    font-size: 1.4rem;
    font-weight: 300;
    color: #ffffff;
    flex-shrink: 0;
    line-height: 1;
    transition: transform 0.2s;
  }

  details[open] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-answer {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.65;
    padding: 0 4px 18px;
    margin: 0;
  }
</style>
